# Install Sensei CLI + desktop app via Homebrew.
# Usage: brew bundle

tap "mizukisu/tap", "https://github.com/mizukisu/homebrew-tap"

brew "mizukisu/tap/sensei"        # CLI + background server daemon
cask "mizukisu/tap/sensei-app"    # Desktop app (optional)
cask "ollama"                       # Local AI inference (optional, used by indexer)
