#!/usr/bin/env bash
# Pre-tool execution hook — logs tool usage to sensei daemon
# Runs before each tool call in Claude Code

DAEMON_URL="http://127.0.0.1:7744"
PROJECT_ROOT="${CLAUDE_PROJECT_ROOT:-${PWD}}"
PROJECT_NAME="$(basename "$PROJECT_ROOT")"
TOOL_NAME="${CLAUDE_TOOL_NAME:-unknown}"
SESSION_ID="${CLAUDE_SESSION_ID:-}"

# Log to daemon (fire-and-forget)
curl -s -X PUT "${DAEMON_URL}/api/config" \
  -H "Content-Type: application/json" \
  -d "{\"last_tool\":\"${TOOL_NAME}\",\"last_tool_project\":\"${PROJECT_NAME}\",\"last_tool_time\":\"$(date -u +%Y-%m-%dT%H:%M:%S+00:00)\"}" \
  --connect-timeout 1 --max-time 2 >/dev/null 2>&1 &

# Return empty — no context injection needed for pre-tool
echo '{}'
exit 0
