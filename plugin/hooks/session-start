#!/usr/bin/env bash
set -euo pipefail

DAEMON_URL="http://127.0.0.1:7744"
PROJECT_ROOT="${CLAUDE_PROJECT_ROOT:-${PWD}}"
PROJECT_NAME="$(basename "$PROJECT_ROOT")"

escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

# ── Create session on daemon ─────────────────────────────────────────────────
# Fire-and-forget — don't block session start if daemon is down
SESSION_ID=$(uuidgen 2>/dev/null || python3 -c "import uuid; print(uuid.uuid4())" 2>/dev/null || echo "")
if [ -n "$SESSION_ID" ]; then
  curl -s -X POST "${DAEMON_URL}/api/sessions" \
    -H "Content-Type: application/json" \
    -d "{\"id\":\"${SESSION_ID}\",\"repoId\":\"${PROJECT_NAME}\",\"task\":\"session\"}" \
    --connect-timeout 2 --max-time 3 >/dev/null 2>&1 &
fi

# ── Always-on rules ──────────────────────────────────────────────────────────

CONTEXT="<package-manager-rule>
Before running any shell command in a JavaScript or TypeScript project, determine the package manager by reading the root package.json:
- \"packageManager\": \"bun@...\"  → use bun
- \"packageManager\": \"pnpm@...\" → use pnpm
- \"packageManager\": \"npm@...\"  → use npm
- No field: check lock files — bun.lock/bun.lockb → bun, pnpm-lock.yaml → pnpm, package-lock.json → npm

Rules (no exceptions):
1. Never use npm, npx, bunx, or direct binary calls when a root script exists for the same purpose
2. Always run root scripts: <pm> run <script>
3. For workspace targeting: <pm> run <script> --filter=<package-name>
4. Inner package scripts are a fallback only — use when no root script exists
</package-manager-rule>

<sensei-session>
Session ID: ${SESSION_ID}
Project: ${PROJECT_NAME}
Path: ${PROJECT_ROOT}
Use sensei MCP tools (search, get_lib_docs, get_callers, etc.) for code intelligence.
Call update_session with this session ID when the task is complete.
</sensei-session>"

ESCAPED=$(escape_for_json "$CONTEXT")

cat <<EOF
{
  "additional_context": "${ESCAPED}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${ESCAPED}"
  }
}
EOF
exit 0
