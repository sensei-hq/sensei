Table "gateway"."fallback_chains" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "name" TEXT [not null, unique, note: 'Unique chain name (e.g. "reasoning", "embed", "classify", "consensus-proposer").']
  "capability" model_capability [not null, note: 'Which capability this chain serves: chat, reasoning, embed, classify, summarize, vision, audio.']
  "description" TEXT [note: 'What this chain is for (e.g. "MOE proposer — strong reasoning models").']
  "max_fallback_attempts" INTEGER [not null, default: 3, note: 'Maximum number of models to attempt before failing.']
  "is_active" BOOLEAN [not null, default: true, note: 'Whether this chain is available for use.']
  "sequence" INTEGER [not null, default: 0, note: 'Display order — lower values shown first.']
  "modified_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp of the last modification to this row.']

  Note: '''
Ordered model fallback sequences per capability.
When a model fails (timeout, rate limit, error), the gateway tries the next in sequence.
- capability: which model_capability this chain handles (chat, reasoning, embed, etc.)
- max_fallback_attempts: how many models to try before giving up
Seed data loaded via staging.import_fallback_chains().
'''
}

Table "gateway"."providers" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "name" TEXT [not null, unique, note: 'Unique slug identifier (e.g. "anthropic", "meta", "google").']
  "display_name" TEXT [not null, note: 'Human-readable name (e.g. "Anthropic", "Meta").']
  "description" TEXT [note: 'Brief description of the provider.']
  "website_url" TEXT [note: 'Provider homepage URL.']
  "is_open_source" BOOLEAN [not null, default: false, note: 'Whether the provider primarily offers open-source models.']
  "is_active" BOOLEAN [not null, default: true, note: 'Whether models from this provider are available for selection.']
  "sequence" INTEGER [not null, default: 0, note: 'Display order — lower values shown first.']
  "modified_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp of the last modification to this row.']

  Note: '''
AI model organizations — OpenAI, Anthropic, Meta, Google, Alibaba, etc.
Seed data loaded via staging.import_providers().
'''
}

Table "gateway"."routers" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "name" TEXT [not null, unique, note: 'Unique slug identifier (e.g. "ollama", "anthropic", "openai").']
  "display_name" TEXT [not null, note: 'Human-readable name (e.g. "Ollama (local)", "Anthropic").']
  "description" TEXT [note: 'Brief description of this router.']
  "router_type" router_type [not null, note: 'Router category: direct (single provider), aggregator (multi-provider), local (on-device).']
  "api_base_url" TEXT [note: 'Base URL for API calls (e.g. "http://localhost:11434", "https://api.anthropic.com").']
  "api_key_env_var" TEXT [note: 'Environment variable name containing the API key (e.g. "ANTHROPIC_API_KEY"). Null for local routers.']
  "authentication_type" auth_type [not null, default: 'api_key', note: 'How to authenticate: api_key (header-based) or none (local).']
  "default_headers" JSONB [not null, default: '{}', note: 'Default HTTP headers for requests to this router.']
  "rate_limits" JSONB [not null, default: '{}', note: 'Rate limits: {requests_per_minute, tokens_per_minute}.']
  "config" JSONB [not null, default: '{}', note: 'Connection config: {timeout_ms, retry_limit, retry_delay_ms, circuit_breaker_threshold, circuit_breaker_window_minutes}.']
  "is_active" BOOLEAN [not null, default: true, note: 'Whether this router is available for use.']
  "sequence" INTEGER [not null, default: 0, note: 'Display order — lower values shown first.']
  "modified_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp of the last modification to this row.']

  Note: '''
API access points for LLM gateway.
- direct: single-provider API (anthropic, openai)
- aggregator: multi-provider proxy (openrouter)
- local: on-device runtime (ollama)
- config: connection settings — {timeout_ms, retry_limit, retry_delay_ms, circuit_breaker_threshold, ...}
- rate_limits: {requests_per_minute, tokens_per_minute}
Seed data loaded via staging.import_routers().
'''
}

Table "history"."past_extensions" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "extension_id" UUID [not null, note: 'References sensei.extensions.id. No FK — survives hard deletes.']
  "plugin_id" UUID
  "kind" TEXT [not null]
  "name" TEXT [not null]
  "version" TEXT
  "description" TEXT
  "content" TEXT
  "props" JSONB [not null, default: '{}']
  "scope" TEXT [not null]
  "enabled" BOOLEAN [not null]
  "source" TEXT [not null]
  "icons" JSONB [not null, default: '{}']
  "tags" TEXT[] [not null, default: '{}']
  "operation" dml_operation [not null, note: 'DML that produced this entry: INSERT, UPDATE, or DELETE.']
  "revision" INTEGER [not null, default: 0, note: 'Revision number of the extension at this snapshot.']
  "recommendation_id" UUID [note: 'Which recommendation triggered this change. Null for manual edits. Links to inference.recommendations.']
  "effective_from" TIMESTAMPTZ [not null, note: 'When this revision became the live state.']
  "effective_to" TIMESTAMPTZ [note: 'When this revision was superseded. Null if still current or if source was deleted.']
  "changed_at" TIMESTAMPTZ [not null, default: `now()`, note: 'When this history entry was written.']
  "changed_by" TEXT [note: 'Who triggered the change: user, recommendation:{id}, system.']

  indexes {
    extension_id [name: 'past_extensions_extension_id_idx']
    recommendation_id [name: 'past_extensions_recommendation_idx']
  }

  Note: '''
History table for sensei.extensions — auto-populated by historize_extensions trigger.
Captures every INSERT, UPDATE, and DELETE so that skill/persona/rule changes can be
audited and correlated with FTR impact via recommendation_id.

- extension_id: references sensei.extensions.id with no FK — survives hard deletes
- recommendation_id: which recommendation triggered this change (null for manual edits)
- effective_from/to: when this revision was the live state
- operation: INSERT, UPDATE, or DELETE
'''
}

Table "history"."past_memories" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "memory_id" UUID [not null, note: 'References sensei.memories.id. No FK — survives hard deletes.']
  "project_id" UUID
  "scope" TEXT [not null]
  "scope_filter" TEXT
  "type" TEXT [not null]
  "title" TEXT [not null]
  "content" TEXT [not null]
  "impact" TEXT
  "strength" REAL [not null]
  "status" TEXT [not null]
  "session_id" UUID
  "operation" dml_operation [not null, note: 'DML that produced this entry: INSERT, UPDATE, or DELETE.']
  "effective_from" TIMESTAMPTZ [not null, note: 'When this revision became the live state.']
  "effective_to" TIMESTAMPTZ [note: 'When this revision was superseded. Null if still current or if source was deleted.']
  "changed_at" TIMESTAMPTZ [not null, default: `now()`, note: 'When this history entry was written.']

  indexes {
    memory_id [name: 'past_memories_memory_id_idx']
  }

  Note: '''
History table for sensei.memories — auto-populated by historize_memories trigger.
Captures every INSERT, UPDATE, and DELETE so that memory evolution can be audited.

- memory_id: references sensei.memories.id with no FK — survives hard deletes
- effective_from/to: when this revision was the live state
- operation: INSERT, UPDATE, or DELETE
'''
}

Table "inference"."insight_batches" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "insight_count" INTEGER [not null, default: 0, note: 'Number of insights in this batch.']
  "target" TEXT [not null, note: 'Where insights were sent: git, posthog.']
  "reference" TEXT [note: 'External reference: git commit SHA, PostHog batch ID, etc.']
  "sent_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp when this batch was sent.']

  Note: '''
Collective intelligence send batches. Groups insights shared together.
- target: "git", "posthog" — where insights were sent
- reference: git commit SHA, PostHog batch ID, etc. — traceable external reference
'''
}

Table "sensei"."assistants" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "family" assistant_family [not null, note: 'Assistant product family: claude, cursor, zed, continue, codex, aider, opencode, kiro.']
  "name" TEXT [not null, note: 'Specific variant or display name (e.g. "Claude Code CLI", "Cursor").']
  "version" TEXT [note: 'Detected version of the assistant binary/app.']
  "path" TEXT [note: 'Filesystem path to the assistant binary or config directory.']
  "transport" TEXT [not null, default: 'stdio', note: 'Communication transport: stdio (pipes) or http (localhost).']
  "configured" BOOLEAN [not null, default: false, note: 'True once sensei has registered its extensions (skills, commands, hooks, MCP) with this assistant.']
  "configured_at" TIMESTAMPTZ [note: 'Timestamp of the last configuration/registration run. Null if never configured.']
  "configured_version" TEXT [note: 'Sensei version string at last configuration. Bootstrap compares this to running version to trigger upgrade reconfiguration.']
  "props" JSONB [not null, default: '{}', note: 'Extra metadata: {detected_at, install_method, registration_log, capabilities, supported_hooks, last_health_check}.']
  "modified_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp of the last modification to this row.']

  indexes {
    family [name: 'assistants_family_idx']
    configured [name: 'assistants_configured_idx']
  }

  Note: '''
Detected AI coding assistants (ACPs) and their configuration state.
Bootstrap detects installed assistants and upserts rows here.
Setup wizard (step 3) registers sensei plugins/skills/commands per assistant.
On upgrade, bootstrap compares configured_version against the running sensei
version — if stale, the upgrade flow re-pushes skills, agents, hooks, and
commands to each configured assistant.

- family: groups variants of the same product (e.g. claude covers claude-code CLI and claude-code desktop)
- transport: stdio or http — how sensei communicates with this assistant
- configured: true once sensei has registered its extensions with this assistant
- configured_at: when registration last ran (null = never configured)
- configured_version: sensei version at last configuration — drives upgrade reconfiguration
- props: extra metadata — {detected_at, install_method, registration_log, capabilities}
'''
}

Table "sensei"."config" {
  "key" TEXT [pk, not null, note: 'Preference key.']
  "value" TEXT [not null, note: 'Preference value stored as text (JSON-encoded for complex values).']

  Note: '''
Key-value user preferences.
setup_complete, active_project, sidebar_max_items, etc.
'''
}

Table "sensei"."extensions" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "plugin_id" UUID [note: 'Self-referencing FK: null = standalone, set = belongs to a plugin extension.']
  "kind" extension_kind [not null, note: 'Extension type: plugin (container), skill, command, agent, or hook.']
  "name" TEXT [not null, unique, note: 'Unique identifier (e.g. "zero-errors-policy", "sensei:build").']
  "version" TEXT [note: 'Semantic version string.']
  "description" TEXT [note: 'Triggering conditions or purpose description (starts with "Use when..." for skills).']
  "content" TEXT [note: 'Markdown body — the actual skill protocol, command instructions, or agent definition.']
  "props" JSONB [not null, default: '{}', note: 'Parsed frontmatter + config: {triggers, inputs, tool_access, hook_event, ...}.']
  "scope" extension_scope [not null, default: 'global', note: 'Visibility: global (all projects), project (one project), folder (one repository).']
  "enabled" BOOLEAN [not null, default: true, note: 'Whether this extension is currently active.']
  "source" extension_source [not null, default: 'local', note: 'Origin: builtin (ships with sensei), marketplace (installed from registry), local (user-created).']
  "icons" JSONB [not null, default: '{}', note: 'Display icons: {emoji, devicon, kanji, custom}.']
  "tags" TEXT[] [not null, default: '{}', note: 'Array of tag strings for filtering. Vocabulary controlled by sensei.tags table.']
  "revision" INTEGER [not null, default: 0]
  "modified_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp of the last modification to this row.']
  "modified_by" TEXT

  indexes {
    plugin_id [name: 'extensions_plugin_id_idx']
    kind [name: 'extensions_kind_idx']
    tags [name: 'extensions_tags_idx']
  }

  Note: '''
Skills, commands, agents, hooks, and plugins.
Plugins are containers — other extensions reference them via plugin_id (self-ref).
- content: markdown body — the actual skill/command text, editable and round-trippable to .md files
- props: parsed frontmatter + additional config (triggers, inputs, tool_access, etc.)
- scope: global (all projects), project (specific project), folder (specific repository)
- source: builtin (ships with sensei), marketplace (installed), local (user-created)
- plugin_id: null = standalone extension; set = belongs to a plugin
'''
}

Table "sensei"."folders_to_watch" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "path" TEXT [not null, unique, note: 'Absolute filesystem path to the watched root directory.']
  "name" TEXT [not null, note: 'Display name for the root (e.g. "Developer", "Work Projects").']
  "note" TEXT [note: 'Optional user note about this root (e.g. "monorepo root, 3 packages").']
  "status" watch_status [not null, default: 'scanning', note: 'Lifecycle: scanning (initial scan in progress), watching (watchers active), paused (content retained, watchers stopped).']
  "excluded" JSONB [not null, default: '[]', note: 'JSON array of relative folder names/paths excluded from scanning, e.g. ["node_modules","dist",".git"].']
  "modified_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp of the last modification to this row.']

  Note: '''
Configuration: directories the user has pointed sensei at.
Initial status is scanning; transitions to watching after first scan completes.
Exclusions are user configuration — adding an entry deletes matching folders + children;
removing an entry triggers a re-scan of that subtree.
'''
}

Table "sensei"."libraries" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "kind" library_kind [not null, default: 'detected', note: 'Library classification: detected (from package manifests) or imported (manually registered).']
  "name" TEXT [not null, note: 'Package name within the ecosystem (e.g. "react", "tokio", "@lumen/icons").']
  "ecosystem" library_ecosystem [not null, note: 'Package registry: npm, pypi, cargo, go, or docs (pure documentation source).']
  "version" TEXT [note: 'Pinned or latest-known version string.']
  "description" TEXT [note: 'Human-readable description of the library.']
  "source_type" library_source_type [note: 'How documentation pages are sourced: llms.txt, http, or local.']
  "base_url" TEXT [note: 'Root URL for fetching documentation when source_type is http or llms.txt.']
  "local_path" TEXT [note: 'Local filesystem path for reading documentation when source_type is local.']
  "homepage_url" TEXT [note: 'URL of the library homepage or repository.']
  "docs_url" TEXT [note: 'URL of the library primary documentation site.']
  "page_count" INTEGER [not null, default: 0, note: 'Denormalized count of library_pages rows for this library.']
  "embedding" vector(384) [note: '384-dimensional vector embedding on description for similarity search.']
  "icons" JSONB [not null, default: '{}', note: 'Display icons: {emoji, devicon, kanji, custom}.']
  "props" JSONB [not null, default: '{}', note: 'Extensible metadata: {llms_txt, llms_txt_fetched_at, skill_path, skill_generated_at, ...}.']
  "tags" TEXT[] [not null, default: '{}', note: 'Array of tag strings for filtering. Vocabulary controlled by sensei.tags table.']
  "indexed_at" TIMESTAMPTZ [note: 'Timestamp of the last successful index run for this library.']
  "modified_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp of the last modification to this row.']

  indexes {
    kind [name: 'libraries_kind_idx']
    embedding [name: 'libraries_embedding_hnsw']
    tags [name: 'libraries_tags_idx']
  }

  Note: '''
Libraries — known packages and documentation sources.
Consolidates the former libraries, lib_meta, and shared_libs tables.
- kind: detected (from Cargo.toml, package.json) or imported (manual, internal SDKs, llms.txt)
- ecosystem: npm, pypi, cargo, go, or docs (for pure documentation sources)
- source_type: how pages are fetched — llms.txt, http, or local
- page_count: denormalized count of library_pages rows
- props: extensible — {llms_txt, llms_txt_fetched_at, skill_path, skill_generated_at, ...}
- embedding: 384-dim vector on description for similarity search
'''
}

Table "sensei"."projects" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "name" TEXT [not null, note: 'Project display name — initially derived from parent folder name or git remote.']
  "description" TEXT [note: 'Optional project description.']
  "client" TEXT [note: 'Optional client or owner name.']
  "maturity" project_maturity [not null, default: 'discovery', note: 'Lifecycle stage: discovery (just scanned), active (in development), maintenance, or archived.']
  "goal" TEXT [note: 'What this project is for — populated from README, sensei.json, or user input.']
  "icon" JSONB [not null, default: '{}', note: 'Display icon: {kind:"kanji"|"emoji"|"custom", value:"工", bg:"color", fg:"color"}.']
  "stack" JSONB [not null, default: '{}', note: 'Detected technology stack: {languages:[], frameworks:[], runtimes:[], services:[]}. Derived from member folders.']
  "commands" JSONB [not null, default: '{}', note: 'JSON object of common commands: {dev, test, build, lint, ...}. Derived from config files.']
  "links" JSONB [not null, default: '[]', note: 'External references: [{id, kind, label, url}]. Kinds: docs, dashboard, issues, runbook, design, wiki.']
  "guidelines" JSONB [not null, default: '[]', note: 'Project rules: [{id, rule, source}]. Source can be "house-style", a session id, or "manual".']
  "preferred_acp" TEXT [note: 'Default AI coding tool for sessions in this project: claude-code, cursor, zed, etc.']
  "backlog" JSONB [not null, default: '[]', note: 'Task backlog items: [{id, task, added}]. Surfaced in project settings.']
  "privacy" JSONB [not null, default: '{}', note: 'Per-project privacy settings: {logPrompts:bool, logFileContents:bool, redactSecrets:bool, shareWithCloud:bool}. Defaults to empty = inherit global config.']
  "excluded_globs" JSONB [not null, default: '[]', note: 'Glob patterns to exclude from indexing for this project: ["dist/**", "*.generated.*"]. Layered on top of folders_to_watch.excluded.']
  "tags" TEXT[] [not null, default: '{}', note: 'Array of tag strings for quick filtering. Vocabulary controlled by sensei.tags table.']
  "modified_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp of the last modification to this row.']

  indexes {
    maturity [name: 'projects_maturity_idx']
    tags [name: 'projects_tags_idx']
  }

  Note: '''
Projects — independent grouping entity for 1+ folders.
One project per git/subtree folder by default, but users can merge or split.
- maturity: discovery → active → maintenance → archived
- stack: {languages, frameworks, runtimes, services} — derived from member folders
- icon: {kind, value, bg, fg} — e.g. {kind:"kanji", value:"工", bg:"var(--shu-soft)", fg:"var(--shu)"}
- links: external references [{id, kind, label, url}] — docs, dashboards, issue trackers
- guidelines: project rules [{id, rule, source}]
- preferred_acp: default AI coding tool for this project (claude-code, cursor, etc.)
- backlog: task items [{id, task, added}]
- privacy: per-project privacy settings {logPrompts, logFileContents, redactSecrets, shareWithCloud}
- excluded_globs: file/folder patterns to exclude from indexing ["dist/**", "*.generated.*"]
'''
}

Table "sensei"."services" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "name" TEXT [not null, unique, note: 'Unique identifier for the service (e.g. "postgres-mcp").']
  "display_name" TEXT [not null, note: 'Human-readable name (e.g. "PostgreSQL MCP").']
  "publisher" TEXT [note: 'Who publishes this service (e.g. "supabase", "stripe").']
  "protocol" service_protocol [not null, default: 'mcp', note: 'Communication protocol: mcp (tools via http/stdio), ollama (local inference), anthropic/openai (external LLM providers).']
  "kind" service_kind [not null, note: 'Service category: data (databases), api (external APIs), devtool (dev tools), service (monitoring etc.), inference (local/external LLM providers).']
  "summary" TEXT [note: 'Short description of what this service provides.']
  "trigger_stacks" TEXT[] [not null, default: '{}', note: 'Stack names that trigger recommendation of this service (e.g. ["PostgreSQL","Redis"]).']
  "tools_count" INTEGER [not null, default: 0, note: 'Number of tools exposed by this service.']
  "verified" BOOLEAN [not null, default: false, note: 'Whether the service is verified/official.']
  "installed" BOOLEAN [not null, default: false, note: 'Whether the service is currently installed and configured.']
  "config" JSONB [not null, default: '{}', note: 'Connection config: MCP: {transport, command, args, url, env}. Ollama: {url, models, default_model}. External: {api_key_env, default_model}.']
  "icons" JSONB [not null, default: '{}', note: 'Display icons: {emoji, devicon, kanji, custom}.']
  "tags" TEXT[] [not null, default: '{}', note: 'Array of tag strings for filtering. Vocabulary controlled by sensei.tags table.']
  "modified_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp of the last modification to this row.']

  indexes {
    kind [name: 'services_kind_idx']
    installed [name: 'services_installed_idx']
    tags [name: 'services_tags_idx']
  }

  Note: '''
External service registry for MCP servers and inference providers.
- kind: data (databases), api (stripe, github), devtool (playwright, figma), service (sentry, etc.), inference (Ollama, external LLM providers)
- protocol: mcp (tools via http/stdio), ollama (local inference), anthropic/openai (external inference)
- trigger_stacks: which detected stacks recommend this service (e.g. ["PostgreSQL"])
- config: connection config, env vars, transport settings, model preferences
'''
}

Table "sensei"."tags" {
  "tag" TEXT [pk, not null, note: 'Tag text value — the controlled vocabulary entry.']
  "category" TEXT [note: 'Optional category for grouping tags (e.g. "stack", "domain", "status").']
  "modified_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp when this tag was first created.']

  Note: '''
Controlled vocabulary for tags used across the system.
Tables that need tags carry a tags text[] column for quick access.
This table provides autocomplete and validation.
- category: optional grouping (e.g. "stack", "domain", "status")
'''
}

Table "sensei"."workflow_state" {
  "project" TEXT [pk, not null, note: 'Project identifier.']
  "active_phase" TEXT [note: 'Current phase name.']
  "active_plan" TEXT [note: 'Current plan or goal.']
  "active_task" TEXT [note: 'Current task description.']
  "active_issue" INTEGER [note: 'Current issue number being addressed.']
  "last_checkpoint" TEXT [note: 'Timestamp of last checkpoint command.']
  "rules_hash" TEXT [note: 'Hash of active rules for this project.']
  "updated_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp of last update.']

  Note: '''
Workflow state — current phase/task/issue per project.
Updated by checkpoint and phase commands.
'''
}

Table "staging"."benchmark_reports" {
  "id" UUID
  "folder_id" UUID
  "run_name" TEXT
  "strategy" TEXT
  "score" NUMERIC
  "tokens" INTEGER
  "elapsed_ms" INTEGER
  "payload" JSONB
  "promoted" BOOLEAN
  "modified_at" TIMESTAMPTZ

  indexes {
    id [unique, name: 'benchmark_reports_id_ukey']
  }

  Note: 'Staging buffer for sensei.benchmark_reports.'
}

Table "staging"."fallback_chain_models" {
  "chain_name" TEXT
  "router_name" TEXT
  "model_full_name" TEXT
  "sequence_order" INTEGER
  "max_retries" INTEGER [default: 1]
  "is_active" BOOLEAN [default: true]
  "modified_at" TIMESTAMPTZ [not null, default: `now()`]
}

Table "staging"."fallback_chains" {
  "name" TEXT
  "capability" TEXT
  "description" TEXT
  "max_fallback_attempts" INTEGER [default: 3]
  "is_active" BOOLEAN [default: true]
  "sequence" INTEGER [default: 0]
  "modified_at" TIMESTAMPTZ [not null, default: `now()`]
}

Table "staging"."libraries" {
  "name" TEXT
  "ecosystem" TEXT
  "kind" TEXT
  "version" TEXT
  "description" TEXT
  "source_type" TEXT
  "base_url" TEXT
  "local_path" TEXT
  "homepage_url" TEXT
  "docs_url" TEXT
  "icons" JSONB [default: '{}']
  "props" JSONB [default: '{}']
  "tags" TEXT[] [default: '{}']
  "modified_at" TIMESTAMPTZ

  indexes {
    (ecosystem, name) [unique, name: 'libraries_ukey']
  }

  Note: 'Staging buffer for sensei.libraries. Natural key: (ecosystem, name).'
}

Table "staging"."models" {
  "provider_name" TEXT
  "name" TEXT
  "version" TEXT
  "variant" TEXT
  "full_name" TEXT
  "display_name" TEXT
  "description" TEXT
  "capabilities" TEXT[]
