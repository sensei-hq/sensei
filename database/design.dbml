}

Table "staging"."routers" {
  "name" TEXT
  "display_name" TEXT
  "description" TEXT
  "router_type" TEXT
  "api_base_url" TEXT
  "api_key_env_var" TEXT
  "authentication_type" TEXT [default: 'api_key']
  "default_headers" JSONB [default: '{}']
  "rate_limits" JSONB [default: '{}']
  "config" JSONB [default: '{}']
  "is_active" BOOLEAN [default: true]
  "sequence" INTEGER [default: 0]
  "modified_at" TIMESTAMPTZ [not null, default: `now()`]
}

Table "gateway"."inference_assignments" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "role" inference_role [not null, note: 'Inference role: inference (insights/recommendations), consolidation (memory merge/conflict), embedding (index/retrieval), voice (observatory speech), default_fallback (catch-all).']
  "chain_id" UUID [not null, note: 'Foreign key to fallback_chains — the ordered model sequence that serves this role.']
  "is_default_fallback" BOOLEAN [not null, default: false, note: 'When true, this chain is the last-resort fallback for the role. Exactly one per role.']
  "modified_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp of the last modification to this row.']

  indexes {
    role [name: 'inference_assignments_role_idx']
  }

  Note: '''
Maps sensei inference roles to gateway fallback chains.
Each role (inference, consolidation, embedding, voice) is served by one or more
fallback chains. The default_fallback role is a catch-all chain used when a
role-specific chain is exhausted or missing.

- role: which reasoning purpose this chain serves
- chain_id: FK to fallback_chains — the ordered model sequence
- is_default_fallback: true on exactly one row per role — marks which chain
  to use as the last-resort fallback before giving up

Setup wizard (step 9) writes these rows. Users can later reconfigure from
Settings → Inference.
'''
}

Table "gateway"."models" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "provider_id" UUID [not null, note: 'Foreign key to providers — who created this model.']
  "name" TEXT [not null, note: 'Model family name (e.g. "gemma3", "claude", "gpt").']
  "version" TEXT [note: 'Version string (e.g. "3", "4o", "4.5").']
  "variant" TEXT [note: 'Variant within version (e.g. "27b", "haiku", "mini"). Nullable.']
  "full_name" TEXT [not null, note: 'Complete model identifier (e.g. "gemma3:27b", "claude-haiku-4-5", "gpt-4o-mini").']
  "display_name" TEXT [not null, note: 'Human-readable display name.']
  "description" TEXT [note: 'Brief description of model strengths and intended use.']
  "capabilities" model_capability[] [not null, default: '{}', note: 'Array of capabilities this model supports: chat, reasoning, embed, classify, summarize, vision, audio.']
  "context_window" INTEGER [note: 'Maximum input context in tokens.']
  "max_output_tokens" INTEGER [note: 'Maximum output tokens per request.']
  "parameters_count" BIGINT [note: 'Model parameter count (e.g. 27000000000 for 27B).']
  "memory_gb" NUMERIC(5,1) [note: 'RAM required to run locally via Ollama. Null for external-only models.']
  "license_type" TEXT [note: 'License type: commercial, apache-2.0, llama-3, gemma, etc.']
  "released_on" DATE [note: 'Model release date.']
  "deprecated_on" DATE [note: 'Deprecation date. Null if active.']
  "props" JSONB [not null, default: '{}', note: 'Extensible config: {temperature_range, top_p_range, training_cutoff, ...}.']
  "is_active" BOOLEAN [not null, default: true, note: 'Whether this model is available for selection.']
  "modified_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp of the last modification to this row.']

  indexes {
    provider_id [name: 'models_provider_id_idx']
    capabilities [name: 'models_capabilities_idx']
  }

  Note: '''
AI model definitions with capabilities, sizing, and memory requirements.
- capabilities: array of model_capability enum — chat, reasoning, embed, classify, summarize, vision, audio
- memory_gb: RAM required to run locally via Ollama (null for external-only models)
- parameters_count: model parameter count in raw number (e.g. 27000000000 for 27B)
- props: extensible — {temperature_range, top_p_range, training_cutoff, ...}
Seed data loaded via staging.import_models().
'''
}

Table "inference"."insights" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "batch_id" UUID [note: 'Foreign key to insight_batches — which send batch included this insight. Null until shared.']
  "source_table" TEXT [not null, note: 'Source table name: recommendation_outcomes, detected_patterns, sessions, etc.']
  "source_id" UUID [not null, note: 'Primary key of the source record in source_table.']
  "category" TEXT [not null, note: 'Insight category: pattern, model, skill, correction, ftr, anti_pattern, tool, stack.']
  "payload" JSONB [not null, default: '{}', note: 'Anonymized snapshot of the insight at share time. No code, paths, or identifiable info.']

  indexes {
    batch_id [name: 'insights_batch_id_idx']
    category [name: 'insights_category_idx']
  }

  Note: '''
Collective intelligence — references to local insights shared with the network.
Points to source records in recommendation_outcomes, detected_patterns, sessions, etc.
- source_table: which table the original insight lives in
- source_id: PK of the source record
- payload: anonymized snapshot of the insight at time of sharing
- batch_id: null until shared; links to the batch it was sent in
'''
}

Table "inference"."reasoning_traces" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "project_id" UUID [note: 'Foreign key to projects — which project this reasoning was about. Nullable for system-level.']
  "trigger_event" TEXT [not null, note: 'What triggered this reasoning: ftr_drop, recurring_correction, pattern_emerging, negative_impact, etc.']
  "trigger_detail" JSONB [not null, default: '{}', note: 'Context for the trigger: {ftr_delta, sessions, module, ...}.']
  "models_used" TEXT[] [not null, default: '{}', note: 'Array of model identifiers used in the reasoning panel.']
  "exchanges" JSONB [not null, default: '[]', note: 'Full debate: [{model, role, content, tokens}] in order.']
  "consensus" JSONB [not null, default: '{}', note: 'Final consensus: {conclusion, confidence:0.0-1.0, disagreements:[]}.']
  "action_proposed" JSONB [note: 'Recommendation generated from this reasoning, if any.']

  indexes {
    project_id [name: 'reasoning_traces_project_id_idx']
  }

  Note: '''
MOE consensus panel reasoning traces. Stores the full debate between local models.
- trigger_event: what initiated the reasoning (ftr_drop, recurring_correction, pattern_emerging, etc.)
- models_used: ["gemma3:27b", "qwen3:14b", ...]
- exchanges: [{model, role:"proposer"|"challenger"|"synthesizer", content, tokens}]
- consensus: {conclusion, confidence, disagreements:[]}
- action_proposed: the recommendation generated, if any
'''
}

Table "sensei"."folders" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "root_id" UUID [not null, note: 'Foreign key to folders_to_watch — which watched root this folder was discovered under.']
  "parent_id" UUID [note: 'Self-referencing FK for folder hierarchy. Null means direct child of the watch root.']
  "project_id" UUID [note: 'Foreign key to projects — groups this folder into a project. Nullable.']
  "kind" folder_kind [not null, default: 'git', note: 'Folder classification: git (repository), workspace_member (monorepo member), subtree (nested git repo), sibling (non-git sibling), standalone (non-git, no git siblings).']
  "status" folder_status [not null, default: 'discovered', note: 'Indexing lifecycle: discovered → queued → indexing → indexed. Or deferred (not indexed — sibling/standalone). Or failed.']
  "role" folder_role [note: 'Project role assigned during setup: backend, frontend, library, docs, infra. Null until assigned.']
  "name" TEXT [not null, note: 'Display name — typically the directory basename.']
  "path" TEXT [not null, note: 'Path relative to the watch root (e.g. "clients/acme/api").']
  "abs_path" TEXT [not null, unique, note: 'Absolute filesystem path for watcher setup and deduplication.']
  "stack" JSONB [not null, default: '[]', note: 'Detected technology stack as JSON array: ["rust", "typescript"]. Set by ProcessGitFolder from config files (Cargo.toml, package.json, etc.).']
  "remote_urls" JSONB [not null, default: '[]', note: 'JSON array of git remotes: [{name: "origin", url: "git@..."}]. Empty for non-git folders.']
  "icons" JSONB [not null, default: '{}', note: 'JSON object for display icons: {emoji, devicon, custom}.']
  "props" JSONB [not null, default: '{}', note: 'Extensible JSON metadata. For git/subtree: {role, lang, files, loc, stack:{languages,frameworks,runtimes}, libs, indexed_at, last_error, duplicate_of, label}.']
  "tags" TEXT[] [not null, default: '{}', note: 'Array of tag strings for quick filtering. Vocabulary controlled by sensei.tags table.']
  "modified_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp of the last modification to this row.']

  indexes {
    root_id [name: 'folders_root_id_idx']
    parent_id [name: 'folders_parent_id_idx']
    kind [name: 'folders_kind_idx']
    status [name: 'folders_status_idx']
    project_id [name: 'folders_project_id_idx']
    tags [name: 'folders_tags_idx']
  }

  Note: '''
Content: discovered filesystem tree. Every entry was found by scanning a watched root.
- kind: git (repository), workspace_member (monorepo member), subtree (nested git repo), sibling (non-git sibling of git folders), standalone (non-git, no git siblings)
- status: discovered (found), queued (files counted), indexing (in progress), indexed (complete), failed, deferred (not indexed — sibling/standalone)
- stack: detected technology stack ["rust", "typescript", "svelte"] — set by ProcessGitFolder
- path: relative to the watch root
- abs_path: absolute path on disk (unique across all roots)
- parent_id: null = direct child of watch root; set = child of another folder
- project_id: FK to projects — auto-created 1:1 for git/subtree, user can merge/split
'''
}

Table "sensei"."library_pages" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "library_id" UUID [not null, note: 'Foreign key to libraries — which library this page belongs to.']
  "title" TEXT [not null, note: 'Title of this documentation page/section.']
  "url" TEXT [note: 'Remote URL this page was fetched from, if sourced over HTTP or llms.txt.']
  "local_path" TEXT [note: 'Local filesystem path this page was read from, if sourced locally.']
  "description" TEXT [note: 'Short summary of this page content.']
  "content" TEXT [note: 'Full text content of this documentation page.']
  "source_type" library_source_type [not null, note: 'How this page was obtained: llms.txt, http, or local.']
  "component" TEXT [note: 'Optional sub-component or topic label within the library.']
  "embedding" vector(768) [note: '768-dimensional vector embedding for semantic search.']
  "fetched_at" TIMESTAMPTZ [note: 'Timestamp when this page content was last fetched or refreshed.']
  "modified_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp of the last modification to this row.']

  indexes {
    library_id [name: 'library_pages_library_id_idx']
    embedding [name: 'library_pages_embedding_hnsw']
  }

  Note: '''
Documentation pages/sections for libraries.
Consolidates the former lib_doc_sections, shared_lib_sections, and lib_docs tables.
- One row per content page fetched from a library source (llms.txt, HTTP, or local)
- url: the remote URL if fetched over HTTP (absolute URL or path from llms.txt)
- local_path: filesystem path if sourced locally
- component: sub-topic within the library (e.g. "routing", "middleware")
- embedding: 768-dim vector for semantic search
'''
}

Table "sensei"."memories" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "project_id" UUID [note: 'Foreign key to projects. Null = global memory (applies to all projects).']
  "scope" memory_scope [not null, default: 'project', note: 'When to surface: global (always), project (this project), stack (matching tech), task_type (matching task), module (matching code area).']
  "scope_filter" TEXT [note: 'Qualifier for scope: stack name (e.g. "rust"), task type (e.g. "fix"), module path (e.g. "src/api"). Null for global/project scope.']
  "type" memory_type [not null, note: 'Knowledge category: decision (architectural), pattern (code convention), convention (team norm), preference (style rule), continuity (session handoff), question (open issue).']
  "title" TEXT [not null, note: 'Short label used as heading in context output.']
  "content" TEXT [not null, note: 'The rule or learning — full body text surfaced to the agent.']
  "impact" TEXT [note: 'Consequence of ignoring this memory. Answers "what breaks if you skip this?"']
  "strength" REAL [not null, default: 1.0, note: 'Confidence score 0–5. Created at 1.0, reinforced +1.0, confirmed = 5.0, decayed over time. Below 1.0 = auto-archived.']
  "status" memory_status [not null, default: 'active', note: 'Lifecycle: active (newly learned), reinforced (evidence accumulated), challenged (violated recently), battle_tested (high strength + zero violations over time), archived (retained for history, not surfaced).']
  "reinforced_count" INTEGER [not null, default: 0, note: 'Number of times evidence has confirmed this memory.']
  "violated_count" INTEGER [not null, default: 0, note: 'Number of times this memory was violated (assistant acted contrary to it).']
  "last_relevant_at" TIMESTAMPTZ [note: 'Timestamp of last reinforcement or violation. Used for recency-based surfacing.']
  "session_id" UUID [note: 'Session that created this memory. Null for imported or collective memories.']
  "modified_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp of the last modification to this row.']

  indexes {
    (project_id, scope, status) [name: 'memories_project_id_idx']
    (scope, scope_filter) [name: 'memories_scope_idx']
    strength [name: 'memories_strength_idx']
  }

  Note: '''
Multi-level, reasoned, evolving knowledge system.
Replaces memory_items (project-scoped only) and inference.preferences (style rules).
- scope: determines when this memory is surfaced — global, project, stack, task_type, module
- scope_filter: qualifier for non-global scopes (stack name, task type, module path)
- impact: consequence of ignoring this memory — the "why"
- strength: 0–5 score, reinforced by evidence, decayed by time
- session_id: session that created this memory (provenance)

Context assembly: SELECT active memories matching scope hierarchy for current session.
'''
}

Table "activity"."sessions" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "folder_id" UUID [not null, note: 'Foreign key to folders — which folder this session ran in.']
  "project_id" UUID [note: 'Foreign key to projects — derived from folder.']
  "task" TEXT [not null, default: '', note: 'Task description passed at get_session_context.']
  "acp_id" TEXT [note: 'Assistant family name (matches sensei.assistants.family): claude, cursor, codex, aider, etc.']
  "outcome" session_outcome [note: 'Session outcome: completed, corrected, blocked, partial, abandoned.']
  "ftr" BOOLEAN [note: 'First-Try Rate: true if zero corrections.']
  "turns" INTEGER [not null, default: 0, note: 'Number of user turns.']
  "corrections" INTEGER [not null, default: 0, note: 'Number of user corrections (FTR detractor).']
  "tokens_in" INTEGER [note: 'Total input tokens consumed.']
  "tokens_out" INTEGER [note: 'Total output tokens generated.']
  "duration_ms" INTEGER [note: 'Session duration in milliseconds.']
  "module" TEXT [note: 'Primary code module touched. For per-module FTR.']
  "summary" TEXT [note: 'Brief summary of what happened in this session. Populated at checkpoint time by the assistant.']
  "props" JSONB [not null, default: '{}', note: 'Extensible: {patterns_matched, personas_applied, workflow_phase, ...}.']
  "started_at" TIMESTAMPTZ [not null, default: `now()`, note: 'When this session started.']
  "completed_at" TIMESTAMPTZ [note: 'When this session ended.']

  indexes {
    (folder_id, started_at) [name: 'sessions_folder_id_idx']
    (project_id, started_at) [name: 'sessions_project_id_idx']
    ftr [name: 'sessions_ftr_idx']
  }

  Note: '''
AI coding sessions captured by hooks.
- outcome: completed (no corrections), corrected, blocked, partial (crash), abandoned
- ftr: true if corrections == 0 (First-Try Rate)
- module: primary code module touched (for per-module FTR tracking)
- props: {patterns_matched, personas_applied, workflow_phase, ...}
'''
}

Table "gateway"."fallback_chain_models" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "chain_id" UUID [not null, note: 'Foreign key to fallback_chains — which chain this entry belongs to.']
  "router_id" UUID [not null, note: 'Foreign key to routers — which API endpoint to use for this attempt.']
  "model_id" UUID [not null, note: 'Foreign key to models — which model to try at this position.']
  "sequence_order" INTEGER [not null, note: 'Position in the chain: 1 = primary, 2 = first fallback, etc.']
  "max_retries" INTEGER [not null, default: 1, note: 'How many times to retry this specific model before moving to next in chain.']
  "is_active" BOOLEAN [not null, default: true, note: 'Whether this chain entry is currently active.']
  "modified_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp of the last modification to this row.']

  indexes {
    chain_id [name: 'fallback_chain_models_chain_id_idx']
  }

  Note: '''
Ordered model entries within a fallback chain.
sequence_order defines the try-order: 1 = first attempt, 2 = first fallback, etc.
Seed data loaded via staging.import_fallback_chain_models().
'''
}

Table "gateway"."models_in_router" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "router_id" UUID [not null, note: 'Foreign key to routers — which API endpoint serves this model.']
  "model_id" UUID [not null, note: 'Foreign key to models — which model is available.']
  "router_model_id" TEXT [not null, note: 'The model identifier used by this router (e.g. "gemma3:27b", "claude-haiku-4-5-20251001").']
  "cost_per_input_token" NUMERIC(12,10) [not null, default: 0, note: 'Cost per input token in USD. 0 for local models.']
  "cost_per_output_token" NUMERIC(12,10) [not null, default: 0, note: 'Cost per output token in USD. 0 for local models.']
  "cost_per_request" NUMERIC(10,6) [not null, default: 0, note: 'Fixed cost per request in USD. 0 for most models.']
  "is_active" BOOLEAN [not null, default: true, note: 'Whether this model-router combination is currently usable.']
  "is_default" BOOLEAN [not null, default: false, note: 'Whether this is the primary endpoint for this model.']
  "props" JSONB [not null, default: '{}', note: 'Extensible: {max_concurrent, supports_streaming, supports_tools, ...}.']
  "modified_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp of the last modification to this row.']

  indexes {
    router_id [name: 'models_in_router_router_id_idx']
    model_id [name: 'models_in_router_model_id_idx']
  }

  Note: '''
Junction: which models are available on which router, with pricing.
- router_model_id: the identifier the router uses for this model (e.g. "gemma3:27b" for Ollama, "claude-haiku-4-5-20251001" for Anthropic)
- cost_per_input/output_token: 0 for local routers (Ollama), per-token pricing for external
- is_default: primary endpoint for this model (if available on multiple routers)
- props: extensible — {max_concurrent, supports_streaming, supports_tools, ...}
Seed data loaded via staging.import_models_in_router().
'''
}

Table "inference"."communities" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "folder_id" UUID [not null, note: 'Foreign key to folders — which repo this community was detected in.']
  "community_id" INTEGER [not null, note: 'Leiden-assigned cluster integer. Matches nodes.community_id.']
  "label" TEXT [note: 'Human-readable label for this community (e.g. "auth module", "CRDT sync").']
  "description" TEXT [note: 'One-paragraph summary of what this community does.']
  "node_count" INTEGER [not null, default: 0, note: 'Number of nodes assigned to this community.']
  "god_node_ids" UUID[] [not null, default: '{}', note: 'UUIDs of top-5 highest-degree nodes in this community.']
  "computed_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp when Leiden algorithm last ran for this cluster.']
  "modified_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp of the last modification to this row.']

  indexes {
    folder_id [name: 'communities_folder_id_idx']
  }

  Note: '''
Leiden algorithm community clusters. Computed offline as a batch job.
- community_id: integer cluster ID (referenced by nodes.community_id)
- god_node_ids: top-5 highest-degree nodes in this community
- node_count: denormalized count of nodes in this cluster
'''
}

Table "inference"."detected_patterns" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "folder_id" UUID [not null, note: 'Foreign key to folders — which folder this pattern was detected in.']
  "name" TEXT [not null, note: 'Pattern name (e.g. "Adapter", "Duplicated auth guard", "God node · router.ts").']
  "family" TEXT [note: 'Pattern family: GoF · structural, GoF · behavioral, resilience, data-access, etc.']
  "lifecycle" pattern_lifecycle [not null, default: 'suggested', note: 'Pattern state: suggested (emerging), gap (recommended but absent), rule (enforced in sessions).']
  "is_anti_pattern" BOOLEAN [not null, default: false, note: 'True for anti-patterns (duplication, god-node, monolith, dead-code, copy-paste).']
  "severity" pattern_severity [note: 'Anti-pattern severity: low, medium, high. Null for positive patterns.']
  "confidence" NUMERIC(3,2) [note: 'Detection confidence score 0.00-1.00.']
  "instance_count" INTEGER [not null, default: 0, note: 'Number of code locations where this pattern is detected.']
  "instances" JSONB [not null, default: '[]', note: 'JSON array: [{file, line, snippet}] — specific code locations.']
  "evidence" JSONB [not null, default: '[]', note: 'JSON array: [{session_id, file, description}] — sessions/files that confirmed this pattern.']
  "fix_pattern_id" UUID [note: 'For anti-patterns: self-ref FK to the constructive pattern that would fix this issue.']
  "description" TEXT [note: 'Human-readable description of the pattern and why it matters.']
  "example" TEXT [note: 'Code example showing the pattern in use (or the anti-pattern to avoid).']
  "enforcement" TEXT [note: 'How this pattern is enforced when lifecycle = rule (e.g. "new auth integrations must adapt, not inline").']
  "tags" TEXT[] [not null, default: '{}', note: 'Array of tag strings for filtering.']
  "detected_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp when this pattern was first detected.']
  "modified_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp of the last modification to this row.']

  indexes {
    folder_id [name: 'detected_patterns_folder_id_idx']
    lifecycle [name: 'detected_patterns_lifecycle_idx']
    is_anti_pattern [name: 'detected_patterns_anti_pattern_idx']
    tags [name: 'detected_patterns_tags_idx']
  }

  Note: '''
Code patterns detected during indexing and analysis.
- lifecycle: suggested (emerging, 2+ places) → gap (recommended but absent) → rule (enforced)
- is_anti_pattern: true for duplication, god-nodes, monoliths, dead code, copy-paste
- fix_pattern_id: for anti-patterns, self-ref to the constructive pattern that would fix it
- evidence: [{session_id, file, line, description}] — sessions/files where pattern was observed
- instances: [{file, line, snippet}] — specific code locations
- family: GoF category (structural, behavioral, creational), resilience, data-access, etc.
'''
}

Table "inference"."hyperedges" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "folder_id" UUID [not null, note: 'Foreign key to folders — which repo this hyperedge belongs to.']
  "kind" hyperedge_kind [not null, note: 'Hyperedge category: flow, group, co_change, addressed_by.']
  "label" TEXT [note: 'Human-readable label (e.g. "auth refresh flow", "CRDTOp implementations").']
  "description" TEXT [note: 'Description of what this group of nodes represents.']
  "confidence" edge_confidence [not null, default: 'extracted', note: 'How this hyperedge was detected: extracted, inferred, ambiguous.']
  "member_count" INTEGER [not null, default: 0, note: 'Denormalized count of members.']
  "modified_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp of the last modification to this row.']

  indexes {
    folder_id [name: 'hyperedges_folder_id_idx']
    kind [name: 'hyperedges_kind_idx']
  }

  Note: '''
Multi-node relationships (3+ nodes simultaneously).
- flow: all functions in an auth flow or request pipeline
- group: all implementations of an interface, all files in a module
- co_change: files that always change together (from git history)
- addressed_by: all requirements addressed by a single session
Members stored in hyperedge_members.
'''
}

Table "inference"."recommendations" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "project_id" UUID [not null, note: 'Foreign key to projects — which project this targets.']
  "reasoning_trace_id" UUID [note: 'Foreign key to reasoning_traces — the MOE debate that produced this. Nullable for heuristic.']
  "urgency" recommendation_urgency [not null, default: 'medium', note: 'Priority: high (recurring failures), medium (emerging patterns), low (housekeeping).']
  "status" recommendation_status [not null, default: 'pending', note: 'Lifecycle: pending → accepted, dismissed, or superseded.']
  "title" TEXT [not null, note: 'Short title (e.g. "Write an auth integration-test persona").']
  "why" TEXT [not null, note: 'Why this matters, with evidence summary.']
  "impact" TEXT [note: 'Projected impact (e.g. "Projected FTR +14%").']
  "evidence" JSONB [not null, default: '[]', note: 'JSON array: [{session_id, file, description}] — what triggered this.']
  "action_type" TEXT [not null, note: 'What to do: create_persona, promote_pattern, enable_skill, fix_anti_pattern, audit_stale, revise_rule.']
  "action_detail" JSONB [not null, default: '{}', note: 'Specifics: {persona_name, pattern_id, skill_id, cwd, ...}.']
  "prompt" TEXT [note: 'Ready-to-send prompt for the ACP. Shown in the action drawer.']
  "default_acp" TEXT [note: 'Suggested ACP: claude-code, cursor, codex, etc.']
  "baseline_ftr" NUMERIC(4,3) [note: 'Project FTR snapshot at time of acceptance (acted_at). Null until accepted.']
  "current_ftr" NUMERIC(4,3) [note: 'Rolling project FTR after the change. Updated during measurement.']
  "verdict" recommendation_verdict [not null, default: 'pending', note: 'Impact: positive (FTR improved), negative (FTR dropped), neutral, pending.']
  "props" JSONB [not null, default: '{}', note: 'Extensible: {baseline_corrections_avg, current_corrections_avg, tool_usage_delta, ...}.']
  "acted_at" TIMESTAMPTZ [note: 'Timestamp when the user accepted — the point-in-time marker for before/after FTR comparison.']
  "measured_at" TIMESTAMPTZ [note: 'Timestamp when verdict was last computed.']

  indexes {
    (project_id, status) [name: 'recommendations_project_id_idx']
    urgency [name: 'recommendations_urgency_idx']
    verdict [name: 'recommendations_verdict_idx']
  }

  Note: '''
The full lifecycle: insight → recommendation → action → measurement.

A recommendation is a point-in-time event. When accepted, it marks the moment
something changed in the system (persona added, pattern promoted, skill enabled).
FTR trend before vs after that point tells us if it helped.

Lifecycle: pending → accepted (user acts) → measured (verdict assigned)
                   → dismissed (user skips)
                   → superseded (newer recommendation replaces)

- baseline_ftr: project FTR at the time recommendation was accepted (acted_at)
- current_ftr: rolling FTR after the change
- verdict: positive (FTR improved), negative (FTR dropped), neutral, pending
- measured_at: when verdict was last computed
'''
}

Table "sensei"."benchmark_reports" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "folder_id" UUID [note: 'Foreign key to folders — which folder this report covers. Nullable.']
  "run_name" TEXT [not null, note: 'Human-readable label for this benchmark report.']
  "strategy" TEXT [not null, note: 'Strategy evaluated in this report.']
  "score" NUMERIC [note: 'Benchmark score achieved.']
  "tokens" INTEGER [note: 'Total token count consumed.']
  "elapsed_ms" INTEGER [note: 'Wall-clock duration in milliseconds.']
  "payload" JSONB [note: 'Detailed results as JSON.']
  "promoted" BOOLEAN [not null, default: false, note: 'Whether this strategy has been promoted as active.']
  "modified_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp of the last modification to this row.']

  Note: 'Benchmark reports — results from strategy comparison runs.'
}

Table "sensei"."benchmark_runs" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "folder_id" UUID [not null, note: 'Foreign key to folders — which folder this benchmark ran against.']
  "task_description" TEXT [not null, note: 'Coding task given to the AI during this run.']
  "branch" TEXT [not null, note: 'Git branch the benchmark was executed against.']
  "sensei_enabled" BOOLEAN [not null, note: 'Whether sensei MCP tools were available (false = baseline, true = assisted).']
  "started_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp when the run began.']
  "ended_at" TIMESTAMPTZ [note: 'Timestamp when the run finished. Null if in progress.']
  "total_cost_usd" NUMERIC(10,6) [note: 'Total API cost in USD aggregated from api_requests.']
  "total_input_tokens" INTEGER [note: 'Total input tokens across all API calls.']
  "total_output_tokens" INTEGER [note: 'Total output tokens across all API calls.']
  "total_cache_read_tokens" INTEGER
  "total_cache_creation_tokens" INTEGER
  "worktree_path" TEXT [note: 'Path of the temporary git worktree used. Deleted after completion.']
  "modified_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp of the last modification to this row.']

  indexes {
    (folder_id, task_description, branch) [name: 'benchmark_runs_folder_idx']
  }

  Note: 'One row per benchmark execution (paired: same task + branch, sensei_enabled true/false).'
}

Table "sensei"."index_errors" {
  "id" serial [pk, increment, not null, note: 'Surrogate primary key (serial).']
  "folder_id" UUID [not null, note: 'Foreign key to folders — which folder this error occurred in.']
  "file_path" TEXT [not null, note: 'Path to the file that failed to index.']
  "error" TEXT [not null, note: 'Error message or stack trace.']
  "adapter" TEXT [note: 'Language adapter that produced the error.']
  "phase" TEXT [note: 'Indexing phase when the error occurred.']
  "created_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp when this error was recorded.']

  indexes {
    folder_id [name: 'idx_index_errors_folder']
  }

  Note: 'Files that failed during indexing. Persisted for debugging.'
}

Table "sensei"."memory_evidence" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "memory_id" UUID [not null, note: 'Foreign key to memories — which memory this evidence supports.']
  "session_id" UUID [not null, note: 'References activity.sessions.id. No FK — cross-schema reference.']
  "note" TEXT [note: 'What happened: correction, reinforcement, or contradiction.']
  "modified_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp of the last modification to this row.']

  indexes {
    memory_id [name: 'memory_evidence_memory_id_idx']
  }

  Note: '''
Sessions that prove or reinforce a memory.
Each row is one piece of evidence — a session where the memory was learned,
confirmed, or contradicted. Used for strength scoring.

- session_id: references activity.sessions.id. No FK — sessions may be in a separate schema/DB.
- note: what happened in this session (e.g. "user corrected indentation twice")
'''
}

Table "sensei"."memory_examples" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "memory_id" UUID [not null, note: 'Foreign key to memories — which memory this example supports.']
  "node_id" TEXT [not null, note: 'References hierarchy_nodes.id. No FK — survives node deletion.']
  "is_good" BOOLEAN [not null, note: 'True = good example (follow this), false = bad example (avoid this).']
  "note" TEXT [note: 'Why this code is a good or bad example for this memory.']
  "modified_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp of the last modification to this row.']

  indexes {
    memory_id [name: 'memory_examples_memory_id_idx']
  }

  Note: '''
Code examples grounding a memory in real code.
- node_id: references a hierarchy node (file, function, class, etc.)
- is_good: true = canonical implementation to follow, false = divergence to avoid
- note: why this example matters for this memory

No FK on node_id — nodes may be deleted when code changes, but the example record
stays as historical evidence. The note should describe the example independently.
'''
}

Table "sensei"."memory_links" {
  "parent_id" UUID [pk, not null, note: 'The consolidated memory that replaced the children.']
  "child_id" UUID [pk, not null, note: 'An original memory that was merged into the parent.']
  "modified_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp of the last modification to this row.']

  indexes {
    child_id [name: 'memory_links_child_id_idx']
  }

  Note: '''
Memory-to-memory relationships for consolidation.
When multiple memories are combined into one, the combined memory becomes the parent
and the originals become children. Children are then historized into past_memories.

- parent_id: the consolidated/surviving memory
- child_id: the original memory that was merged in
'''
}

Table "sensei"."nodes" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "folder_id" UUID [not null, note: 'Foreign key to folders — which repo this node belongs to.']
  "parent_id" UUID [note: 'Self-referencing FK for containment hierarchy. Null = top-level in file.']
  "kind" node_kind [not null, note: 'Node classification. See table comment for full list.']
  "name" TEXT [not null, note: 'Identifier name or heading text.']
  "file_path" TEXT [not null, note: 'Folder-relative path of the source file. Denormalized for query performance.']
  "signature" TEXT [note: 'Abbreviated type signature (L0 level). For code symbols.']
  "description" TEXT [note: 'Human-readable description (L1 level). For code symbols or doc summary.']
  "content" TEXT [note: 'Full content text (L2/L3). For doc sections: markdown body. For rationale: comment text.']
  "docstring" TEXT [note: 'Extracted JSDoc/TSDoc/rustdoc comment. For code symbols.']
  "line_start" INTEGER [note: 'One-based line number where this node begins in the source file.']
  "line_end" INTEGER [note: 'One-based line number where this node ends.']
  "is_exported" BOOLEAN [not null, default: false, note: 'True when the symbol is exported from its file. Only meaningful for code symbols.']
  "community_id" INTEGER [note: 'Leiden community cluster ID. Batch-computed. Null until computed.']
  "degree" INTEGER [note: 'Precomputed in+out edge count. Used for god-node detection.']
  "embedding" vector(384) [note: '384-dim vector embedding for semantic search. Computed by local model during indexing. HNSW indexed.']
  "tags" TEXT[] [not null, default: '{}', note: 'Array of tag strings for filtering.']
  "props" JSONB [not null, default: '{}', note: 'Extensible metadata. For sections: {level:2}. For rationale: {tag:"WHY"}. For files: {language:"rust"}.']
  "modified_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp of the last modification to this row.']

  indexes {
    folder_id [name: 'nodes_folder_id_idx']
    parent_id [name: 'nodes_parent_id_idx']
    kind [name: 'nodes_kind_idx']
    (folder_id, file_path) [name: 'nodes_file_path_idx']
    (folder_id, name) [name: 'nodes_name_idx']
    (folder_id, is_exported) [name: 'nodes_exported_idx']
    community_id [name: 'nodes_community_id_idx']
    embedding [name: 'nodes_embedding_hnsw']
    tags [name: 'nodes_tags_idx']
  }

  Note: '''
Unified node table for the code graph. Every structural element is a node:
files, code symbols, doc sections, rationale comments.

Hierarchy via parent_id:
  file → class → method → parameter
  file → section (H1) → section (H2) → section (H3)
  file → function
  function → rationale (from comments)

Node kinds:
  file — source or doc file within a repo
  module, package — structural containers
  class, interface — type definitions
  function, method — callable code
  property, field, parameter — members
  type, const, enum, enum_variant — value definitions
  section — documentation heading (level stored in props)
  rationale — extracted from NOTE/WHY/HACK/TODO/IMPORTANT comments

file_path is denormalized on every node for fast file-scoped queries.
Relationships between nodes are stored in the edges table.
'''
}

Table "sensei"."referenced_libraries" {
  "folder_id" UUID [pk, not null, note: 'Foreign key to folders — the folder that uses this library.']
  "library_id" UUID [pk, not null, note: 'Foreign key to libraries — the library dependency.']
  "version_used" TEXT [note: 'Version of the library pinned in this folder, as observed from the package manifest.']
  "props" JSONB [not null, default: '{}', note: 'Extensible metadata: {source, usage_count, skill_path, skill_generated_at, ...}.']
  "modified_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp of the last modification to this row.']

  indexes {
    library_id [name: 'referenced_libraries_library_id_idx']
  }

  Note: '''
Junction table linking folders (git/subtree folders) to their library dependencies.
- version_used: the pinned version observed in the folder (from package.json, Cargo.toml, etc.)
- props: extensible — {source:"Cargo.toml", usage_count, skill_path, skill_generated_at, ...}
'''
}

Table "sensei"."scan_state" {
  "folder_id" UUID [pk, not null, note: 'Foreign key to folders — which folder this file belongs to.']
  "file_path" TEXT [pk, not null, note: 'Folder-relative path of the source file being tracked.']
  "mtime" BIGINT [not null, note: 'File modification time as Unix epoch milliseconds, used for quick change detection.']
  "content_hash" TEXT [not null, note: 'SHA-256 hash of the file content used to confirm whether it has changed since last index.']
  "indexed_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp when this file was last successfully indexed.']
  "modified_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp of the last modification to this row.']

  indexes {
    folder_id [name: 'scan_state_folder_id_idx']
    (folder_id, indexed_at) [name: 'scan_state_indexed_at_idx']
  }

  Note: '''
Per-file scan fingerprint used by the indexer to skip unchanged files.
- mtime: file modification time as unix ms
- content_hash: sha256 of file content for change detection
- indexed_at: when this file was last successfully indexed
'''
}

Table "activity"."events" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "session_id" UUID [not null, note: 'Foreign key to sessions — which session this event occurred in.']
  "folder_id" UUID [not null, note: 'Foreign key to folders — which folder context. Denormalized for fast queries.']
  "event_type" event_type [not null, note: 'Event category. Determines the shape of the data payload.']
  "turn_number" INTEGER [note: 'Which turn in the session this event occurred at. Null for non-turn events.']
  "data" JSONB [not null, default: '{}', note: 'Event payload as JSON. Shape determined by event_type — see table comment.']
  "created_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp when this event occurred.']

  indexes {
    (session_id, created_at) [name: 'events_session_id_idx']
    (folder_id, created_at) [name: 'events_folder_id_idx']
    event_type [name: 'events_type_idx']
  }

  Note: '''
Unified activity log for everything that happens during sessions.
Consolidates the former api_requests, task_turns, tool_calls, and events tables.

Event types and their data payloads:
  tool_call:        {tool_name, service_name, input_params, response, duration_ms, used_in_response}
  api_request:      {prompt_id, model, input_tokens, output_tokens, cache_read_tokens, cost_usd, duration_ms}
  correction:       {description, module}
  turn:             {role:"user"|"assistant", token_count}
  phase_transition: {from_phase, to_phase}
  checkpoint:       {summary, next_step}
  task_start:       {task_description, task_type}
  task_end:         {status, ftr_score, ftr_signals}
  context_loaded:   {files_loaded, token_count}
  edit:             {file_path, lines_changed}
  test:             {passed, failed, total}
  error:            {message, adapter, phase}
'''
}

Table "activity"."snapshots" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "session_id" UUID [not null, note: 'Foreign key to sessions.']
  "folder_id" UUID [not null, note: 'Foreign key to folders.']
  "kind" snapshot_kind [not null, note: 'Snapshot type: manual or checkpoint.']
  "progress_summary" TEXT [not null, note: 'Summary of work completed, used for recovery.']
  "next_step_hint" TEXT [note: 'Optional hint for next action when resuming.']
  "completed_steps" TEXT[] [not null, default: '{}', note: 'Ordered list of completed step descriptions.']
  "in_flight_files" TEXT[] [not null, default: '{}', note: 'Paths of files being actively modified at snapshot time.']
  "worktree_refs" JSONB [not null, default: '[]', note: 'JSON array of active git worktrees [{branch, path, status}].']
  "diff_stat_summary" TEXT [note: 'Human-readable diff-stat summary at snapshot time.']
  "created_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp when snapshot was taken.']

  indexes {
    (session_id, created_at) [name: 'snapshots_session_id_idx']
    (folder_id, created_at) [name: 'snapshots_folder_id_idx']
  }

  Note: '''
Point-in-time session state for crash recovery and history.
- kind=manual: take_snapshot at a step boundary
- kind=checkpoint: task complete marker
- in_flight_files: flagged for consistency check on recovery
- worktree_refs: [{branch, path, status}] active git worktrees
'''
}

Table "activity"."task_sessions" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "session_id" UUID [note: 'Foreign key to sessions.']
  "folder_id" UUID [not null, note: 'Foreign key to folders.']
  "task_description" TEXT [note: 'Task description passed at get_session_context.']
  "task_type" task_type_kind [note: 'Auto-detected: feat, fix, refactor, docs, test, chore, unknown.']
  "status" task_status [not null, default: 'in_progress', note: 'Lifecycle: in_progress → completed or abandoned.']
  "ftr_score" NUMERIC(4,3) [note: 'First-Try-Right score 0.000–1.000. Null until checkpoint.']
  "ftr_signals" JSONB [note: 'Raw signal values used to compute ftr_score.']
  "modified_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp of last modification.']
  "completed_at" TIMESTAMPTZ [note: 'Timestamp when task reached terminal state.']

  indexes {
    (folder_id, modified_at) [name: 'task_sessions_folder_id_idx']
    session_id [name: 'task_sessions_session_id_idx']
  }

  Note: '''
Task boundaries within sessions. One row per checkpoint boundary.
- ftr_score: 0.000–1.000, null until checkpoint
- status: in_progress → completed or abandoned
Task-level events (task_start, task_end) are in the events table.
'''
}

Table "inference"."drift_items" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "folder_id" UUID [not null, note: 'Foreign key to folders — which folder this drift was detected in.']
  "doc_node_id" UUID [not null, note: 'Foreign key to nodes — the doc section that references the code.']
  "code_node_id" UUID [note: 'Foreign key to nodes — the code symbol being referenced. Null if broken (deleted).']
  "status" drift_status [not null, default: 'current', note: 'Drift status: current (valid), drifted (signature changed), broken (target deleted).']
  "expected_signature" TEXT [note: 'What the documentation says the symbol looks like.']
  "actual_signature" TEXT [note: 'What the code actually has. Null if the target no longer exists.']
  "detail" TEXT [note: 'Human-readable description of the drift.']
  "detected_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp when this drift was first detected.']
  "resolved_at" TIMESTAMPTZ [note: 'Timestamp when the drift was resolved (doc updated or code reverted). Null if unresolved.']

  indexes {
    folder_id [name: 'drift_items_folder_id_idx']
    status [name: 'drift_items_status_idx']
  }

  Note: '''
Doc-to-code drift tracking. One row per reference from a doc node to a code node.
- current: reference is valid, signatures match
- drifted: target exists but signature changed
- broken: target was deleted or renamed
- expected_signature: what the doc says the symbol looks like
- actual_signature: what the code actually has (null if broken)
'''
}

Table "inference"."hyperedge_members" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "hyperedge_id" UUID [not null, note: 'Foreign key to hyperedges — which hyperedge this member belongs to.']
  "node_id" UUID [not null, note: 'Foreign key to nodes — which node is a member of this hyperedge.']
  "position" INTEGER [note: 'Order position for flow-type hyperedges. Null for unordered groups.']

  indexes {
    hyperedge_id [name: 'hyperedge_members_hyperedge_id_idx']
    node_id [name: 'hyperedge_members_node_id_idx']
  }

  Note: '''
Members of a hyperedge. Links nodes to their hyperedge with optional ordering.
- position: sequence order for flow-type hyperedges (null for unordered groups)
'''
}

Table "sensei"."edges" {
  "id" UUID [pk, not null, default: `gen_random_uuid()`, note: 'Surrogate primary key (UUID).']
  "folder_id" UUID [not null, note: 'Foreign key to folders — which repo this edge belongs to.']
  "source_id" UUID [not null, note: 'Foreign key to nodes — the source node of this relationship.']
  "target_id" UUID [note: 'Foreign key to nodes — the target node. Null if unresolved.']
  "target_name" TEXT [note: 'Name of the target for unresolved edges. Allows lookup without a node.']
  "target_file" TEXT [note: 'File path of the target for unresolved edges.']
  "kind" edge_kind [not null, note: 'Relationship type. See table comment for full list.']
  "confidence" edge_confidence [not null, default: 'extracted', note: 'Edge confidence: extracted (AST-certain), inferred (embedding/BM25), ambiguous (drift/gap).']
  "confidence_score" NUMERIC(3,2) [note: 'Numeric confidence 0.00-1.00. Used for similarity/duplicate edges.']
  "props" JSONB [not null, default: '{}', note: 'Extensible metadata. For imports: {names:["a","b"]}. For duplicates: {similarity:0.86}.']
  "modified_at" TIMESTAMPTZ [not null, default: `now()`, note: 'Timestamp of the last modification to this row.']

  indexes {
    folder_id [name: 'edges_folder_id_idx']
    source_id [name: 'edges_source_id_idx']
    target_id [name: 'edges_target_id_idx']
    kind [name: 'edges_kind_idx']
    confidence [name: 'edges_confidence_idx']
  }

  Note: '''
Typed relationships between nodes in the code graph.

Edge kinds:
  calls — function/method calls another function/method
  implements — class implements interface
  extends — class/interface extends another
  imports — file imports from file/module (props: {names:["useState","useEffect"]})
  depends_on — module-level dependency
  traces_to — documentation traces to code symbol
  references — doc section references a symbol or file
  covers — doc file covers source file
  rationale_for — comment explains a symbol
  duplicates — structurally identical code (confidence_score = similarity)
  similar_to — semantically similar (inferred from embeddings)

target_id is nullable — null when the target node is unresolved (external symbol, unindexed file).
target_name and target_file provide lookup info for unresolved edges.
'''
}

