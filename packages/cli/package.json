{
  "name": "@sensei/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "sensei": "./dist/cli.js",
    "senseid": "./dist/daemon.js"
  },
  "scripts": {
    "dev": "bun run --watch src/cli.ts",
    "build": "bun build src/cli.ts src/daemon.ts --outdir dist --target bun --external=better-sqlite3 && sed -i '' '1s|#!/usr/bin/env node|#!/usr/bin/env bun|' dist/cli.js dist/daemon.js",
    "test": "bunx vitest run",
    "test:e2e": "bunx playwright test",
    "test:watch": "bunx vitest"
  },
  "dependencies": {
    "@sensei/tools": "workspace:*",
    "@sensei/server": "workspace:*",
    "@sensei/shared": "workspace:*",
    "@sensei/graph-indexer": "workspace:*",
    "@sensei/collector": "workspace:*",
    "@sensei/engine": "workspace:*",
    "@anthropic-ai/sdk": "^0.82.0",
    "@clack/prompts": "^1.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.2",
    "better-sqlite3": "^12.8.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  }
}
