{
  "name": "@sensei/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "sensei": "./dist/cli.js"
  },
  "scripts": {
    "dev": "bun run --watch src/cli.ts",
    "build": "bun build src/cli.ts --outdir dist --target bun && sed -i '' '1s|#!/usr/bin/env node|#!/usr/bin/env bun|' dist/cli.js",
    "test": "bunx vitest run",
    "test:e2e": "bunx playwright test",
    "test:watch": "bunx vitest"
  },
  "dependencies": {
    "@sensei/mcp": "workspace:*",
    "@sensei/server": "workspace:*",
    "@sensei/shared": "workspace:*",
    "@anthropic-ai/sdk": "^0.78.0",
    "@clack/prompts": "^0.9.0",
    "fast-glob": "^3.3.0",
    "js-yaml": "^4.1.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.48.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  }
}
