#!/usr/bin/env bash
# Pre-tool execution hook — logs tool usage event to sensei daemon
set -euo pipefail

DAEMON_URL="http://127.0.0.1:7744"
PROJECT_ROOT="${CLAUDE_PROJECT_ROOT:-${PWD}}"
PROJECT_NAME="$(basename "$PROJECT_ROOT")"
TOOL_NAME="${CLAUDE_TOOL_NAME:-unknown}"
SESSION_ID="${CLAUDE_SESSION_ID:-}"

# Read phase context from state.yaml
STATE_FILE="${PROJECT_ROOT}/.sensei/state.yaml"
ACTIVE_PHASE=""
ACTIVE_TASK=""
if [ -f "$STATE_FILE" ]; then
  ACTIVE_PHASE=$(grep "^active_phase:" "$STATE_FILE" 2>/dev/null | sed 's/^active_phase: *//' | sed 's/^~//')
  ACTIVE_TASK=$(grep "^active_task:" "$STATE_FILE" 2>/dev/null | sed 's/^active_task: *//' | sed 's/^~//')
fi

# Detect if MCP tool
IS_MCP=false
if echo "$TOOL_NAME" | grep -q "^mcp__sensei"; then
  IS_MCP=true
fi

# Log event to daemon (fire-and-forget)
curl -s -X POST "${DAEMON_URL}/api/events" \
  -H "Content-Type: application/json" \
  -d "{\"project\":\"${PROJECT_NAME}\",\"session_id\":\"${SESSION_ID}\",\"event_type\":\"tool_used\",\"data\":{\"tool\":\"${TOOL_NAME}\",\"is_mcp\":${IS_MCP},\"phase\":\"${ACTIVE_PHASE}\",\"task\":\"${ACTIVE_TASK}\"}}" \
  --connect-timeout 1 --max-time 2 >/dev/null 2>&1 &

echo '{}'
exit 0
