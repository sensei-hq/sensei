#!/usr/bin/env bash
# Post-tool execution hook — logs tool results to sensei daemon
# Runs after each tool call in Claude Code

DAEMON_URL="http://127.0.0.1:7744"
PROJECT_ROOT="${CLAUDE_PROJECT_ROOT:-${PWD}}"
PROJECT_NAME="$(basename "$PROJECT_ROOT")"
TOOL_NAME="${CLAUDE_TOOL_NAME:-unknown}"
EXIT_CODE="${CLAUDE_TOOL_EXIT_CODE:-0}"
SESSION_ID="${CLAUDE_SESSION_ID:-}"

# Log completion to daemon (fire-and-forget)
curl -s -X PUT "${DAEMON_URL}/api/config" \
  -H "Content-Type: application/json" \
  -d "{\"last_tool_result\":\"${TOOL_NAME}:${EXIT_CODE}\",\"last_tool_result_time\":\"$(date -u +%Y-%m-%dT%H:%M:%S+00:00)\"}" \
  --connect-timeout 1 --max-time 2 >/dev/null 2>&1 &

# Return empty — no context injection needed for post-tool
echo '{}'
exit 0
