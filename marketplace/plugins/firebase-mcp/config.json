{
  "name": "firebase-mcp",
  "description": "Firebase project management — apps, rules, environment config",
  "mcp_server": {
    "command": "npx",
    "args": ["-y", "@anthropic/mcp-firebase"],
    "env": {}
  },
  "supported_acps": ["claude-code", "cursor"],
  "acp_configs": {
    "claude-code": {
      "config_path": ".claude/plugins/firebase/plugin.json",
      "format": "claude-plugin"
    }
  }
}
