#!/usr/bin/env bash
# Post-tool execution hook — logs tool result event to sensei daemon.
# Also captures file paths from Edit/Write tools to power hotspot analysis.
set -euo pipefail

DAEMON_URL="http://127.0.0.1:7744"
PROJECT_ROOT="${CLAUDE_PROJECT_ROOT:-${PWD}}"
PROJECT_NAME="$(basename "$PROJECT_ROOT")"
TOOL_NAME="${CLAUDE_TOOL_NAME:-unknown}"
EXIT_CODE="${CLAUDE_TOOL_EXIT_CODE:-0}"
SESSION_ID="${CLAUDE_SESSION_ID:-}"

# Read stdin JSON (tool_name, tool_input, tool_response)
STDIN_JSON=""
if ! [ -t 0 ]; then
  STDIN_JSON="$(cat)"
fi

# Detect if MCP tool
IS_MCP=false
if echo "$TOOL_NAME" | grep -q "^mcp__sensei"; then
  IS_MCP=true
fi

# Log tool_result event (fire-and-forget)
curl -s -X POST "${DAEMON_URL}/api/events" \
  -H "Content-Type: application/json" \
  -d "{\"project\":\"${PROJECT_NAME}\",\"session_id\":\"${SESSION_ID}\",\"event_type\":\"tool_result\",\"data\":{\"tool\":\"${TOOL_NAME}\",\"exit_code\":${EXIT_CODE},\"is_mcp\":${IS_MCP}}}" \
  --connect-timeout 1 --max-time 2 >/dev/null 2>&1 &

# For Edit/Write tools: emit an 'edit' event with the file path for hotspot tracking
if [ -n "$STDIN_JSON" ] && command -v jq >/dev/null 2>&1; then
  STDIN_TOOL=$(echo "$STDIN_JSON" | jq -r '.tool_name // empty' 2>/dev/null || true)
  if [ "$STDIN_TOOL" = "Edit" ] || [ "$STDIN_TOOL" = "Write" ]; then
    FILE_PATH=$(echo "$STDIN_JSON" | jq -r '.tool_input.file_path // empty' 2>/dev/null || true)
    if [ -n "$FILE_PATH" ]; then
      # Make path relative to project root if absolute
      REL_PATH="$FILE_PATH"
      if [[ "$FILE_PATH" == "$PROJECT_ROOT"* ]]; then
        REL_PATH="${FILE_PATH#"$PROJECT_ROOT"/}"
      fi
      curl -s -X POST "${DAEMON_URL}/api/events" \
        -H "Content-Type: application/json" \
        -d "{\"project\":\"${PROJECT_NAME}\",\"session_id\":\"${SESSION_ID}\",\"event_type\":\"edit\",\"data\":{\"file_path\":\"${REL_PATH}\",\"tool\":\"${STDIN_TOOL}\"}}" \
        --connect-timeout 1 --max-time 2 >/dev/null 2>&1 &
    fi
  fi
fi

echo '{}'
exit 0
