# Playwright test environment
# These values configure the test suite for your local machine.

# Daemon mode — always 'dev' for tests (uses .sensei-dev/ and port 7745)
SENSEI_MODE=dev
SENSEI_PORT=7745

# Local folder to scan during setup wizard tests.
# Use a small fixture — real repos are too large and can crash the daemon.
LOCAL_FOLDER=/tmp/sensei-e2e-fixture

# Path to senseid binary (built from source)
SENSEID_BIN=../../target/debug/senseid
