{
  "name": "sensei",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "bun run --filter='*' build",
    "test": "bunx vitest run",
    "test:e2e": "bun run --filter='*' test:e2e",
    "dev": "bun run --filter='@sensei/cli' dev",
    "coverage": "vitest run --coverage "
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@vitest/coverage-v8": "4.0.18",
    "coverage-v8": "^0.0.1-security",
    "js-yaml": "^4.1.1",
    "vitest": "^4.0.18"
  }
}
