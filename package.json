{
  "name": "sensei",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "bun run --filter='*' build",
    "test": "bunx vitest run",
    "test:e2e": "bun run --filter='*' test:e2e",
    "dev": "bun run --filter='@sensei/cli' dev",
    "coverage": "vitest run --coverage",
    "bump": "bumpp --configFilePath config/bump.config.js",
    "bump:next": "bumpp --configFilePath config/bump.config.js --preid=next",
    "plugin:install": "bun run plugin/scripts/install.ts",
    "plugin:uninstall": "bun run plugin/scripts/uninstall.ts"
  },
  "overrides": {
    "@kavach/sentry": "1.0.0-next.36",
    "@kavach/cookie": "1.0.0-next.36",
    "@kavach/hashing": "1.0.0-next.36",
    "@kavach/logger": "1.0.0-next.36",
    "@kavach/query": "1.0.0-next.36"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@vitest/coverage-v8": "4.0.18",
    "bumpp": "^10.2.3",
    "coverage-v8": "^0.0.1-security",
    "js-yaml": "^4.1.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
