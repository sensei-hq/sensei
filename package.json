{
  "name": "sensei",
  "version": "0.2.13",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "clean": "find packages apps -name 'dist' -maxdepth 5 -type d -exec rm -rf {} + 2>/dev/null; rm -rf apps/desktop/build apps/desktop/.svelte-kit apps/static/.svelte-kit; echo 'clean done'",
    "build": "cd apps/desktop && bun run tauri:build",
    "build:cli": "cargo build --release --manifest-path crates/sensei-cli/Cargo.toml",
    "build:daemon": "cargo build --release --manifest-path crates/senseid/Cargo.toml",
    "build:mcp": "cargo build --release --manifest-path crates/sensei-mcp/Cargo.toml",
    "build:server": "cargo build --release --manifest-path crates/senseid/Cargo.toml && cargo build --release --manifest-path crates/sensei-mcp/Cargo.toml && cargo build --release --manifest-path crates/sensei-cli/Cargo.toml",
    "build:all": "bun run build:server && bun run build",
    "test": "cargo test --manifest-path crates/senseid/Cargo.toml",
    "test:e2e": "cd apps/desktop && npx playwright test",
    "dev": "cd apps/desktop && bun run dev",
    "coverage": "cargo tarpaulin --manifest-path crates/senseid/Cargo.toml --out html --output-dir crates/senseid/coverage",
    "bump": "bumpp --configFilePath config/bump.config.js",
    "bump:next": "bumpp --configFilePath config/bump.config.js --preid=next",
    "upgrade:apps": "find ./apps -type d -depth 1 -exec sh -c 'cd \"{}\" && bun update --latest' \\;",
    "homebrew:push": "git subtree push --prefix=homebrew homebrew main",
    "homebrew:pull": "git subtree pull --prefix=homebrew homebrew main --squash",
    "marketplace:push": "git subtree push --prefix=marketplace marketplace main",
    "marketplace:pull": "git subtree pull --prefix=marketplace marketplace main --squash"
  },
  "devDependencies": {
    "bumpp": "^11.0.1",
    "typescript": "^6.0.2"
  }
}