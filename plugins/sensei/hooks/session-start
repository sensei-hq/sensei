#!/usr/bin/env bash
set -euo pipefail

DAEMON_URL="http://127.0.0.1:7744"
PROJECT_ROOT="${CLAUDE_PROJECT_ROOT:-${PWD}}"
PROJECT_NAME="$(basename "$PROJECT_ROOT")"
PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "$(dirname "$0")/.." && pwd)}"

escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

# ── Create session on daemon ─────────────────────────────────────────────────
SESSION_ID=$(uuidgen 2>/dev/null || python3 -c "import uuid; print(uuid.uuid4())" 2>/dev/null || echo "")
if [ -n "$SESSION_ID" ]; then
  curl -s -X POST "${DAEMON_URL}/api/sessions" \
    -H "Content-Type: application/json" \
    -d "{\"id\":\"${SESSION_ID}\",\"repoId\":\"${PROJECT_NAME}\",\"task\":\"session\"}" \
    --connect-timeout 2 --max-time 3 >/dev/null 2>&1 &
fi

# ── Check daemon health ─────────────────────────────────────────────────
DAEMON_STATUS="unknown"
if curl -s --connect-timeout 1 --max-time 2 "${DAEMON_URL}/health" >/dev/null 2>&1; then
  DAEMON_STATUS="running"
else
  DAEMON_STATUS="NOT RUNNING — MCP tools will be unavailable. Run: sensei start"
fi

# ── Read rules ──────────────────────────────────────────────────────────
RULES_FILE="${PROJECT_ROOT}/.sensei/rules.md"
RULES_SECTION=""
if [ -f "$RULES_FILE" ]; then
  RULES_SECTION="## Project Guardrails (from .sensei/rules.md)

$(cat "$RULES_FILE" | sed '/^---$/,/^---$/d' | head -80)

Run /sensei:rules to view, add, or reload rules."
else
  RULES_SECTION="## Project Guardrails
No rules file found. Run /sensei:rules to create one."
fi

# ── Read mindsets (from .sensei/mindsets/ folder) ────────────────────────────
MINDSETS_DIR="${PROJECT_ROOT}/.sensei/mindsets"
MINDSETS_SECTION=""
if [ -d "$MINDSETS_DIR" ] && ls "$MINDSETS_DIR"/*.md >/dev/null 2>&1; then
  MINDSETS_SECTION="## Mindsets

Apply core three in sequence: Analyst -> Developer -> Acceptance Tester. Apply specialists when domain applies.
"
  for mfile in "$MINDSETS_DIR"/*.md; do
    MNAME=$(sed -n 's/^name: *//p' "$mfile" | head -1)
    MWHEN=$(sed -n 's/^when: *//p' "$mfile" | head -1)
    # Extract questions (lines starting with number + dot + bold)
    MQUESTIONS=$(awk '/^## Questions/{found=1;next} /^## /{found=0} found && /^[0-9]/' "$mfile" | head -7)
    MINDSETS_SECTION="${MINDSETS_SECTION}
### ${MNAME}
*${MWHEN}*
${MQUESTIONS}
"
  done
else
  # Fall back to single file in plugin templates
  MINDSETS_FILE="${PLUGIN_ROOT}/templates/mindsets.md"
  if [ -f "$MINDSETS_FILE" ]; then
    MINDSETS_SECTION="$(sed '/^---$/,/^---$/d' "$MINDSETS_FILE" | head -120)"
  fi
fi

# ── Read personas ────────────────────────────────────────────────────────────
PERSONAS_DIR="${PROJECT_ROOT}/.sensei/personas"
PERSONAS_SECTION=""
if [ -d "$PERSONAS_DIR" ] && ls "$PERSONAS_DIR"/*.md >/dev/null 2>&1; then
  PERSONA_SUMMARIES=""
  for pfile in "$PERSONAS_DIR"/*.md; do
    # Extract frontmatter fields: name, description, validates
    PNAME=$(sed -n 's/^name: *//p' "$pfile" | head -1)
    PDESC=$(sed -n 's/^description: *//p' "$pfile" | head -1)
    PVALIDATES=$(awk '/^validates:/{found=1;next} /^---/{found=0} found && /^  - /{sub(/^  - /,""); print "    - " $0}' "$pfile" | head -5)
    PERSONA_SUMMARIES="${PERSONA_SUMMARIES}
- **${PNAME}** — ${PDESC}
  Validates:
${PVALIDATES}"
  done
  PERSONAS_SECTION="## Project Personas (from .sensei/personas/)
${PERSONA_SUMMARIES}

When validating work, consider each persona's goals and validates criteria."
fi

# ── Read workflow state ──────────────────────────────────────────────────────
STATE_FILE="${PROJECT_ROOT}/.sensei/state.yaml"
STATE_SECTION=""
if [ -f "$STATE_FILE" ]; then
  STATE_SECTION="## Workflow State
$(cat "$STATE_FILE")
Run /sensei:session status for full orientation. Run /sensei:session refocus to re-anchor."
fi

# ── Build context ────────────────────────────────────────────────────────────

CONTEXT="<sensei-session>
Session ID: ${SESSION_ID}
Project: ${PROJECT_NAME}
Path: ${PROJECT_ROOT}
Daemon: ${DAEMON_STATUS}

${STATE_SECTION}

${RULES_SECTION}

${MINDSETS_SECTION}

${PERSONAS_SECTION}

## Sensei MCP Tools (REQUIRED)

You MUST use sensei MCP tools instead of grep/glob for code navigation. These tools use the indexed code graph and return richer results. If MCP tools fail, fall back to grep/glob and report the failure.

**Before implementing any change**, call:
- \`get_patterns(pattern)\` — check existing patterns FIRST. Do not implement without checking.
- \`get_project_summary()\` — understand the codebase structure

**Code Intelligence (use instead of grep/glob):**
- \`search(query, project?)\` — Find functions and types (replaces grep for symbol search)
- \`get_callers(name)\` — Who calls this function? (replaces manual tracing)
- \`get_callees(name)\` — What does this function call?
- \`get_patterns(pattern)\` — Find architectural patterns: hook, middleware, route, component, adapter
- \`get_communities()\` — Code architecture clusters
- \`get_project_summary()\` — Stats, libs, stack

**Library Documentation:**
- \`get_lib_docs(name)\` — Library overview (e.g. rokkit, kavach)
- \`get_lib_docs(name, component)\` — Specific component docs
- \`search_lib_docs(query)\` — Search across all indexed library docs
- \`add_library(name)\` — Index a new library's docs

**Session (call when done):**
- \`update_session(sessionId=\"${SESSION_ID}\", outcome=\"completed\", summary=\"...\")\` — Call when task is done

## Workflow Commands

**Phase:** /sensei:idea, /sensei:analyze, /sensei:blueprint, /sensei:experiment, /sensei:plan, /sensei:build, /sensei:validate
**Cross-cutting:** /sensei:brainstorm, /sensei:review, /sensei:persona, /sensei:agent
**Context:** /sensei:session, /sensei:rules, /sensei:patterns
**Utility:** /sensei:spec, /sensei:checkpoint, /sensei:commit, /sensei:mockup, /sensei:docs, /sensei:help
</sensei-session>

<package-manager-rule>
Before running any shell command in a JavaScript or TypeScript project, determine the package manager by reading the root package.json:
- \"packageManager\": \"bun@...\"  → use bun
- \"packageManager\": \"pnpm@...\" → use pnpm
- \"packageManager\": \"npm@...\"  → use npm
- No field: check lock files — bun.lock/bun.lockb → bun, pnpm-lock.yaml → pnpm, package-lock.json → npm

Rules (no exceptions):
1. Never use npm, npx, bunx, or direct binary calls when a root script exists for the same purpose
2. Always run root scripts: <pm> run <script>
3. For workspace targeting: <pm> run <script> --filter=<package-name>
4. Inner package scripts are a fallback only — use when no root script exists
</package-manager-rule>"

ESCAPED=$(escape_for_json "$CONTEXT")

cat <<EOF
{
  "additional_context": "${ESCAPED}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${ESCAPED}"
  }
}
EOF
exit 0
