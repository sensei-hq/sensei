{
  "name": "playwright-mcp",
  "description": "Browser automation — navigate, click, screenshot, evaluate JS",
  "mcp_server": {
    "command": "npx",
    "args": ["-y", "@anthropic/mcp-playwright"],
    "env": {}
  },
  "supported_acps": ["claude-code", "cursor", "windsurf"],
  "acp_configs": {
    "claude-code": {
      "config_path": ".claude/plugins/playwright/plugin.json",
      "format": "claude-plugin"
    }
  }
}
